NEXT_PUBLIC_APP_NAME=PharmaGuard BotOps QA

# ── AI Provider (AgentRouter is the default OpenAI-compatible provider) ──
AI_PROVIDER=agentrouter
AI_BASE_URL=https://api.agentrouter.io/v1
AI_MODEL=claude-opus-4-7
AGENTROUTER_API_KEY=

# Alternative providers (all OpenAI-compatible, switch via AI_PROVIDER)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── Supabase (optional — app falls back to in-memory store without these) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Embeddings (Google Gemini) ──
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_MODEL=gemini-embedding-001

# ── Upstash Vector (semantic search over bot runs) ──
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ── Upstash Redis (optional caching) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── PharmaGuard Ingestion Security ──
# HMAC key for machine-to-machine automation telemetry (BotCity integration)
PHARMAGUARD_INGEST_KEY=
# Signature timestamp tolerance in seconds (default: 300)
PHARMAGUARD_SIGNATURE_TOLERANCE_SECONDS=300
# Allow insecure dev mode (no HMAC key in non-production) — false by default
PHARMAGUARD_ALLOW_INSECURE_DEV=false

# ── Public Sandbox ──
# Enable public sandbox demo — false by default for safety
PHARMAGUARD_ENABLE_PUBLIC_SANDBOX=false
# Separate secret for signing demo session tokens (NOT the ingest key)
PHARMAGUARD_SANDBOX_SESSION_SECRET=
# Trusted application URL for origin validation (CSRF mitigation)
PHARMAGUARD_APP_URL=http://localhost:3000

# Demo mode — when true and no AI key is set, all summaries use deterministic fallback
DEMO_MODE=true

