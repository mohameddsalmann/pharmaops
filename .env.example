# ──────────────────────────────────────────────────────────────
# PharmaGuard BotOps — Environment Variables
# Copy to .env.local and fill in values.
# Do NOT commit .env.local with real secrets.
# ──────────────────────────────────────────────────────────────

# ── Supabase (database) ──
# Public URL (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Public anon key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER-ONLY — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# ── HMAC Ingest Authentication ──
# Shared secret for signing bot telemetry ingestion requests
PHARMAGUARD_INGEST_KEY=
# Signature timestamp tolerance in seconds (default: 300)
PHARMAGUARD_SIGNATURE_TOLERANCE_SECONDS=300
# Allow insecure dev mode (non-production only, default: false)
PHARMAGUARD_ALLOW_INSECURE_DEV=false

# ── Public Sandbox ──
# Enable the public PMS sandbox (default: false)
PHARMAGUARD_ENABLE_PUBLIC_SANDBOX=false
# Session signing secret for sandbox demo tokens
PHARMAGUARD_SANDBOX_SESSION_SECRET=
# Application URL for origin validation
PHARMAGUARD_APP_URL=http://localhost:3000

# ── Upstash Redis (replay protection & rate limiting) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Upstash Vector (optional, for semantic search) ──
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ── Embedding Service (optional) ──
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_MODEL=gemini-embedding-001

# ── AI / LLM (optional — summaries only, never for scoring) ──
AI_PROVIDER=agentrouter
AI_BASE_URL=https://api.agentrouter.io/v1
AI_MODEL=claude-opus-4-7
# API key (one of these, matched by AI_PROVIDER)
AGENTROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Application ──
# Base URL of the deployment (used for server-side fetch in homepage)
NEXT_PUBLIC_URL=http://localhost:3000

